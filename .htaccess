# CMS BDU - minimal .htaccess for shared hosting compatibility

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /cms/

    # Map extensionless route -> existing .php file
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+)$ $1.php [L]
</IfModule>

# Custom error pages
ErrorDocument 404 /cms/404.php
ErrorDocument 500 /cms/500.php
