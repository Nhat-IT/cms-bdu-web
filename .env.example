DB_HOST=localhost
DB_USER=app_user
DB_PASSWORD=change_me
DB_NAME=cms_bdu
DB_PORT=3306
DB_CONNECTION_LIMIT=1
DB_TIMEZONE=Z
DB_SSL=false
DB_CONNECT_TIMEOUT=10000
PORT=3000
NODE_ENV=development
SESSION_SECRET=change_me_before_production
DB_STARTUP_STRICT=false


# Google Drive integration
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
# Option 1 (recommended in local): absolute or relative path to service account json
GOOGLE_APPLICATION_CREDENTIALS=./secrets/drive-service-account.json
# Option 2 (for CI/CD): full JSON content in one line
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
