DB_HOST=your_db_host
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_PORT=3306
PORT=3000

# Google Drive integration
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
# Option 1 (recommended in local): absolute or relative path to service account json
GOOGLE_APPLICATION_CREDENTIALS=./secrets/drive-service-account.json
# Option 2 (for CI/CD): full JSON content in one line
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
